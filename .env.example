# ============================================
# Replypilot Production Environment Variables
# ============================================

# Node Environment
NODE_ENV=production

# Application
PORT=3000
FRONTEND_URL=https://replypilot.dk
API_URL=https://replypilot.dk
# Frontend API base – for single-domain (Hostinger) deployments this should be
# the same as FRONTEND_URL. If you later move to a Docker + nginx setup with
# a separate API subdomain, you can change it to https://api.replypilot.dk.
VITE_API_BASE_URL=https://replypilot.dk

# Database
DATABASE_URL=postgresql://replypilot:secure_password@postgres:5432/replypilot?sslmode=require

# Redis
REDIS_URL=redis://:secure_redis_password@redis:6379/0

# Session
SESSION_SECRET=your-super-secret-session-key-min-32-chars-long

# Stripe (LIVE MODE) - use your own keys, do NOT commit real secrets
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PRICE_ID=price_your_stripe_price_id

# Twilio (LIVE MODE)
TWILIO_ACCOUNT_SID=AC_your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_MESSAGING_SERVICE_SID=MG_your_messaging_service_sid

# Fonecloud SMS (optional)
FONECLOUD_API_BASE_URL=https://api.fonecloud.example
FONECLOUD_TOKEN=your_fonecloud_token
FONECLOUD_DEFAULT_SENDER_ID=SMS

# Google Gemini AI
GEMINI_API_KEY=your_gemini_api_key

# Groq (free tier; OpenAI-compatible API)
GROQ_API_KEY=your_groq_api_key
# Optional: model (default llama-3.1-8b-instant)
# GROQ_MODEL=llama-3.1-8b-instant

# OpenAI (default provider; used for demo and customer AI)
OPENAI_API_KEY=your_openai_api_key
# Optional: model (default gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini
# Optional: base URL (default https://api.openai.com/v1)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Email Providers

# Option A: SendGrid (existing)
SENDGRID_API_KEY=SG.your_sendgrid_api_key

# Option B: SMTP (Hostinger / other)
# If SENDGRID_API_KEY is empty, the server will try SMTP instead.
# Typical Hostinger settings:
#   SMTP_HOST=smtp.hostinger.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=noreply@replypilot.dk
#   SMTP_PASS=<your mailbox password>
#   SMTP_FROM_EMAIL=noreply@replypilot.dk
#   SMTP_FROM_NAME=Replypilot
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=noreply@replypilot.dk
SMTP_FROM_NAME=Replypilot

# Sentry Error Tracking (optional)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Logging
LOG_LEVEL=info

# ============================================
# Gmail OAuth - For Send-As Aliases Feature
# Get these from: https://console.cloud.google.com/apis/credentials
# ============================================
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_OAUTH_REDIRECT_URI=https://replypilot.dk/api/tenant/email/gmail/callback
GOOGLE_OAUTH_SCOPES=https://www.googleapis.com/auth/gmail.readonly https://www.googleapis.com/auth/gmail.send https://www.googleapis.com/auth/gmail.settings.basic openid email profile

# Microsoft Outlook OAuth (optional)
MICROSOFT_CLIENT_ID=your_microsoft_client_id_here
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret_here
MICROSOFT_OAUTH_REDIRECT_URI=https://replypilot.dk/api/tenant/email/outlook/callback
MICROSOFT_OAUTH_SCOPES=offline_access https://graph.microsoft.com/Mail.Read https://graph.microsoft.com/Mail.Send https://graph.microsoft.com/User.Read

# Email OAuth state signing secret (generate with: openssl rand -base64 32)
EMAIL_OAUTH_STATE_SECRET=your-email-oauth-state-secret-min-32-chars

# ============================================
# Email Service Configuration
# ============================================
EMAIL_SYNC_INTERVAL=2
EMAIL_BATCH_SIZE=25
EMAIL_MAX_RETRIES=5
EMAIL_RETRY_DELAY=5000
EMAIL_RATE_LIMIT_PER_MINUTE=60
EMAIL_RATE_LIMIT_BURST=10

# ============================================
# Security / Auth Secrets
# ============================================

# Tenant JWT – used for tenant-scoped API tokens (min 32 chars)
TENANT_JWT_SECRET=your-tenant-jwt-secret-min-32-characters-long

# Email OAuth state signing secret
EMAIL_OAUTH_STATE_SECRET=your-email-oauth-state-secret-min-32-chars

# Admin panel
ADMIN_FRONTEND_URL=https://admin.replypilot.dk
ADMIN_API_PORT=3100

# Shopify OAuth (optional)
# SHOPIFY_CLIENT_ID=your_shopify_client_id
# SHOPIFY_CLIENT_SECRET=your_shopify_client_secret
# SHOPIFY_REDIRECT_URI=https://replypilot.dk/api/tenant/shops/shopify/callback
# SHOPIFY_SCOPES=read_products,read_orders,read_customers
# SHOPIFY_STATE_SECRET=your-shopify-state-secret-min-32-chars